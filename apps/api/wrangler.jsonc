      "renamed_classes": [{ "from": "ServerRoom", "to": "EnvironmentRoom" }],
    },
    {
      "tag": "v3",
      "deleted_classes": ["EnvironmentRoom"],
    },
  ],
  "observability": {
    "enabled": true,
  },
  "vars": {},
}
