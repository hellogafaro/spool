{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "trunk-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-09-06",
  "durable_objects": {
    "bindings": [
      {
        "name": "SERVER_ROOMS",
        "class_name": "ServerRoom",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ServerRoom"],
    },
  ],
  "observability": {
    "enabled": true,
  },
}
